{
  "description": "Yoohome 个人助手 - Claude Code + DeepSeek 项目配置",
  "model": "deepseek-chat",
  "voice": {
    "enabled": true,
    "mode": "hold",
    "autoSubmit": true
  },
  "env": {
    "PROJECT_NAME": "yoohome-claudecloud",
    "WORKSPACE": "C:\\workspace\\yoohome-claudecloud"
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(python3:*)",
      "Bash(dir)",
      "Bash(ls)",
      "Bash(cat)",
      "Bash(type)",
      "Bash(mkdir:*)",
      "Bash(tsc:*)",
      "Bash(dir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(type:*)",
      "Bash(echo:*)",
      "Bash(rm:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(curl:*)",
      "Bash(taskkill:*)",
      "Bash(netstat:*)",
      "Bash(code:*)",
      "Bash(powershell:*)",
      "Bash(kill:*)",
      "Bash(grep:*)",
      "Bash(cd:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(setx:*)",
      "Bash(reg:*)",
      "Bash(nodemon:*)",
      "WebSearch",
      "WebFetch",
      "Read(*)",
      "Write(*)",
      "Edit(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(npm publish:*)",
      "Bash(curl: *|bash)",
      "Bash(wget: *-O-|sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Yoohome 个人助手已就绪' && echo '工作区: C:\\workspace\\yoohome-claudecloud' && echo '时间: %date% %time%'"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd C:\\workspace\\yoohome-claudecloud && git status --short 2>nul || echo '非 git 仓库或未初始化'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo %date% %time% >> C:\\workspace\\yoohome-claudecloud\\.claude\\session-log.txt"
          }
        ]
      }
    ]
  }
}
